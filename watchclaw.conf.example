# watchclaw.conf — Watchclaw Configuration
# Copy to watchclaw.conf and edit. See README.md for details.

# ── Gateway ──────────────────────────────────────────────────────────
GATEWAY_PORT=18790              # Port to monitor
GATEWAY_CONFIG_DIR="$HOME/.openclaw"    # Must be a git repo with at least one commit
GATEWAY_LOG="/tmp/openclaw-gateway.log"

# OpenClaw binary (auto-detected if on PATH)
# OPENCLAW_BIN="/usr/local/bin/openclaw"

# Extra args passed to openclaw before the gateway subcommand (e.g. --profile sheep)
# OPENCLAW_ARGS=""

# ── Health Check ─────────────────────────────────────────────────────
POLL_INTERVAL_SEC=10                # Seconds between /health polls
HEALTH_TIMEOUT_SEC=5                # curl timeout for health check
# GATEWAY_TLS=1                    # Set to 1 if gateway uses HTTPS (TLS enabled)

# ── Timing ───────────────────────────────────────────────────────────
GRACE_PERIOD_SEC=20                 # Seconds after restart before checking health
PROBATION_DURATION_SEC=60          # 5 min stable → promote to known-good

# ── Retry + Backoff ──────────────────────────────────────────────────
MAX_RETRIES=3                   # Restart attempts before ALERT state
BACKOFF_INITIAL_SEC=300             # 5 min first alert interval
BACKOFF_MAX_SEC=3600                # 1 hour cap

# ── Alert Hook ───────────────────────────────────────────────────────
# Which alert hook to use: imsg | webhook | command | none
ALERT_HOOK="none"

# Hook: imsg (macOS only — requires `imsg` CLI)
# ALERT_IMSG_TO=""              # iMessage address or phone number

# Hook: webhook (any platform)
# ALERT_WEBHOOK_URL=""          # POST URL, message sent as JSON {"text":"..."}

# Hook: command (any platform)
# ALERT_COMMAND=""              # Shell command; message passed as $1

# ── Restart Mode ──────────────────────────────────────────────────────
# How to restart the gateway: native | docker
RESTART_MODE="native"           # native = openclaw gateway start/stop
# DOCKER_CONTAINER=""           # Container name (required when RESTART_MODE=docker)

# ── Logging ──────────────────────────────────────────────────────────
LOG_FILE="./logs/watchclaw.log"
LOG_MAX_BYTES=1048576           # 1MB — rotate when exceeded (keeps .1 backup)

# ── Dry Run ──────────────────────────────────────────────────────────
DRY_RUN=0                       # 1 = log alerts but don't send
